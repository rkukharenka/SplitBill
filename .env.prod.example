# WARNING: Copy to .env on the VPS at /opt/splitbill/.env. NEVER commit real values.

# GitHub Container Registry image (e.g. rkukharenka/splitbill)
GITHUB_REPO=your_github_username/splitbill

# Domain pointing to this VPS
DOMAIN=your.domain.com

# Database
DB_NAME=splitbill
DB_USER=splitbill
DB_PASSWORD=change_me_strong_password

# Redis (no auth by default; add requirepass if needed)

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_URL=https://your.domain.com

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
